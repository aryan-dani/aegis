{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis",
  "version": "0.1.6",
  "identifier": "com.aegis.vault",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aegis",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'none'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFRTJEOTVEREFGMEExMzEKUldReG9mRGFYZG5pL21mdS9hOGhwZDkyckFCN3FVb1cwa3RmRzNyWllxa0FlazdxdVRYeXJMQTkK",
      "endpoints": [
        "https://github.com/aryan-dani/aegis/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
